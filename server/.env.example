# ============================================================
# NOVS-CMR backend configuration. Copy to ".env" and adjust.
# ============================================================

# --- Server ---
PORT=4000
# Comma-separated list of allowed frontend origins (CORS).
CLIENT_ORIGIN=http://localhost:5173

# --- Database (same MongoDB the DB/ layer seeds) ---
# db.js in ../DB/src/config reads this same variable.
MONGO_URI=mongodb://127.0.0.1:27017/novs_cmr

# --- Auth ---
# Change this to a long random string in production.
JWT_SECRET=novs-cmr-dev-secret-change-me
JWT_EXPIRES_IN=8h

# --- Amazon Rekognition (AI-assisted facial scan) ---
# When these are set the facial scan calls the real AWS Rekognition
# DetectFaces API. When ANY are missing the server transparently falls
# back to a deterministic local mock so the whole app still runs offline.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Minimum face confidence / quality thresholds for a PASS.
REKOGNITION_MIN_CONFIDENCE=90
REKOGNITION_MIN_QUALITY=50

# --- Hyperledger Fabric (permissioned audit ledger) ---
# Off-chain pointers are always written to the blockchain_records collection.
# If a real Fabric gateway is available, set FABRIC_ENABLED=true and provide
# the connection profile path; otherwise the service records to MongoDB only.
FABRIC_ENABLED=false
FABRIC_CHANNEL=electoral-channel
FABRIC_CHAINCODE=novs-audit
