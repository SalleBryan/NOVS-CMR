# Copy this file to ".env" and adjust as needed.
# Local MongoDB 8.x (no authentication) - default Windows install.
MONGO_URI=mongodb://127.0.0.1:27017/novs_cmr
DB_NAME=novs_cmr

# When you enable authentication (see scripts/security/setup-roles.mongosh.js),
# use a connection string with the application service account instead, e.g.:
# MONGO_URI=mongodb://novs_app:ChangeMe_App_2026@127.0.0.1:27017/novs_cmr?authSource=novs_cmr

# Backup destination used by scripts/backup/backup.ps1
BACKUP_DIR=C:\NOVS-Backups
